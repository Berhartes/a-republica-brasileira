/* Dashboard Card Base Styles */
.dashboard-card {
  padding: 1.25rem;
  border-radius: 0.75rem;
  cursor: pointer;
  transition: all 0.3s ease;
  color: white;
}

.dashboard-card:hover {
  transform: translateY(-0.25rem);
  box-shadow: 0 20px 25px -5px var(--color-shadow), 0 8px 10px -6px var(--color-shadow);
}

/* Congress Dashboard Styles */
.dashboard-card--congress {
  background-color: var(--color-congress-primary);
  border-left: 4px solid var(--color-congress-secondary);
}

.dashboard-card--congress:hover {
  background-color: var(--color-congress-accent);
}

/* Assembly Dashboard Styles */
.dashboard-card--assembly {
  background-color: var(--color-assembly-primary);
  border-left: 4px solid var(--color-assembly-secondary);
}

.dashboard-card--assembly:hover {
  background-color: var(--color-assembly-accent);
}

/* Government Dashboard Styles */
.dashboard-card--government {
  background-color: var(--color-government-primary);
  border-left: 4px solid var(--color-government-secondary);
}

.dashboard-card--government:hover {
  background-color: var(--color-government-accent);
}

/* Card Content Styles */
.dashboard-card__title {
  font-weight: bold;
  font-size: 1rem;
  line-height: 1.5rem;
  margin-bottom: 0.25rem;
}

.dashboard-card__description {
  font-size: 0.875rem;
  opacity: 0.8;
}

.dashboard-card__value {
  font-size: 2.25rem;
  font-weight: bold;
  margin: 1rem 0;
}

.dashboard-card__badge {
  font-size: 0.75rem;
  font-weight: 500;
  padding: 0.25rem 0.5rem;
  border-radius: 9999px;
  background-color: var(--color-border);
}

.dashboard-card__footer {
  margin-top: 1rem;
  padding-top: 0.75rem;
  border-top: 1px solid var(--color-border);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.dashboard-card__link {
  font-size: 0.875rem;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 0.25rem;
  opacity: 0.9;
  transition: opacity 0.2s ease;
}

.dashboard-card__link:hover {
  opacity: 1;
  text-decoration: underline;
}

/* Icon Styles */
.dashboard-card__icon {
  font-size: 1.25rem;
  margin-right: 0.5rem;
}

/* Focus Styles */
.dashboard-card:focus {
  outline: none;
  ring: 2px solid var(--color-border);
  ring-offset: 2px;
}

/* Badge Variants */
.dashboard-card__badge--gold {
  background-color: #FFD700;
  color: #000;
}

.dashboard-card__badge--green {
  background-color: #4CAF50;
  color: #FFF;
}

.dashboard-card__badge--blue {
  background-color: #2196F3;
  color: #FFF;
}

.dashboard-card__badge--orange {
  background-color: #FF9800;
  color: #000;
}

.dashboard-card__badge--purple {
  background-color: #9C27B0;
  color: #FFF;
}