    "process:legislatura:json": "ts-node scripts/processar_legislatura_export.ts --exportar --formato json",
    "process:legislatura:compressed": "ts-node scripts/processar_legislatura_export.ts --exportar --comprimir",
    "test:legislatura:quick": "ts-node scripts/processar_legislatura_export.ts --exportar",
    "test:legislatura:csv": "ts-node scripts/processar_legislatura_export.ts --exportar --formato csv",
    "test:legislatura:json": "ts-node scripts/processar_legislatura_export.ts --exportar --formato json",
    "extract:mesas": "ts-node scripts/extracao/mesas.ts",
    "process:mesas": "ts-node scripts/processar_mesas.ts",
