    "process:discursos": "ts-node scripts/initiators/processar_discursosdeputados.ts",
    "process:discursos:atualizar": "ts-node scripts/initiators/processar_discursosdeputados.ts --atualizar",
    "process:discursos:quick": "ts-node scripts/initiators/processar_discursosdeputados.ts --limite 10",
    "process:discursos:atualizar:quick": "ts-node scripts/initiators/processar_discursosdeputados.ts --atualizar --limite 10",
    "test:discursos:incremental": "ts-node scripts/utils/test_discursos_incremental.ts",
    
    "camara:perfil": "ts-node -P tsconfig.scripts.json scripts/initiators/processar_perfildeputados_v2.ts",
    "camara:despesas": "ts-node -P tsconfig.scripts.json scripts/initiators/processar_despesasdeputados_v2.ts",
    "camara:discursos": "ts-node -P tsconfig.scripts.json scripts/initiators/processar_discursosdeputados_v2.ts",
    
    "test-etl": "ts-node -P tsconfig.scripts.json scripts/test-etl-system.ts",
    "test-api-camara": "ts-node -P tsconfig.scripts.json scripts/teste-api-camara.ts",
    "test-perfil-corrigido": "npm run test-api-camara",
    
    "camara:perfil:teste": "npm run camara:perfil -- --dry-run --limite 2 --verbose",
    "camara:perfil:rapido": "npm run camara:perfil -- --pc --limite 5 --verbose",
    "camara:perfil:deputado": "npm run camara:perfil -- --deputado",
    
    "lint": "eslint . --ext .ts"
