    "process:mesas:csv": "ts-node scripts/processar_mesas_export.ts --exportar --formato csv",
    "process:mesas:json": "ts-node scripts/processar_mesas_export.ts --exportar --formato json",
    "process:mesas:compressed": "ts-node scripts/processar_mesas_export.ts --exportar --comprimir",
    "test:mesas:quick": "ts-node scripts/processar_mesas_export.ts --exportar --limite 20",
