    "test:blocos:json": "ts-node scripts/processar_blocos_export.ts --exportar --formato json --limite 20",
    "process:senadores:export": "ts-node scripts/processar_senadores_export.ts --exportar",
    "process:senadores:csv": "ts-node scripts/processar_senadores_export.ts --exportar --formato csv",
    "process:senadores:json": "ts-node scripts/processar_senadores_export.ts --exportar --formato json",
    "process:senadores:compressed": "ts-node scripts/processar_senadores_export.ts --exportar --comprimir",
    "test:senadores:quick": "ts-node scripts/processar_senadores_export.ts --exportar --limite 20",
