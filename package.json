{
  "name": "a-republica-brasileira",
  "version": "1.0.0",
  "description": "![Versão](https://img.shields.io/badge/Versão-1.0.0-blue) ![Licença](https://img.shields.io/badge/Licença-MIT-green)",
  "scripts": {
    "estrutura": "tsx src/core/functions/shared/firestore-structure/executar-estrutura.ts",
    "type-check": "tsc --noEmit --project config/typescript/tsconfig.json",
    "dev": "vite --config config/vite/vite.config.ts",
    "build": "tsc --project config/typescript/tsconfig.json && vite build --config config/vite/vite.config.ts",
    "preview": "vite preview",
    "emulators": "tsx tools/scripts/kill-emulators.ts && firebase emulators:start --config=firebase.json",
    "deploy": "firebase deploy --config=firebase.json",
    "deploy:functions": "firebase deploy --only functions --config=firebase.json",
    "start": "tsx src/core/main.ts",
    "test": "vitest",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --coverage-provider=istanbul --reporter=json --reporter=junit --outputFile=./junit.xml",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "dev:full": "concurrently \"npm run emulators\" \"npm run dev\"",
    "fix-firebase": "pnpm remove firebase && pnpm add firebase@10.7.1",
    "update-tanstack": "pnpm remove @tanstack/react-query @tanstack/react-query-devtools @tanstack/query-core @tanstack/query-persist-client-core @tanstack/query-sync-storage-persister && pnpm add @tanstack/react-query@5.69.0 @tanstack/react-query-devtools@5.69.0 @tanstack/query-core@5.69.0 && pnpm add -D @tanstack/query-persist-client-core@5.69.0 @tanstack/query-sync-storage-persister@5.69.0",
    "migrate": "node tools/scripts/migrate-files.js",
    "lint": "eslint src --ext .ts,.tsx",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "stylelint": "stylelint \"**/*.{css,scss}\"",
    "snyk": "snyk test"
  },
